{
  "name": "whatsapp-telegram-renungan-bot",
  "version": "6.0.0",
  "description": "Bot WhatsApp & Telegram untuk Renungan Harian dengan AI - Baileys (No Chromium)",
  "main": "src/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/index.js",
    "start:gc": "node --expose-gc --max-old-space-size=256 src/index.js",
    "start:prod": "node --expose-gc --max-old-space-size=256 --optimize-for-size src/index.js",
    "start:render": "node --max-old-space-size=256 src/index.js",
    "dev": "node --watch src/index.js",
    "tunnel": "cloudflared tunnel --url http://localhost:3000",
    "setup": "node -e \"const os=require('os');if(os.platform()==='win32'){require('child_process').execSync('setup.bat',{stdio:'inherit',shell:'cmd.exe'})}else{require('child_process').execSync('bash setup.sh',{stdio:'inherit'})}\"",
    "setup:render": "bash setup-render.sh",
    "build:render": "bash setup-render.sh"
  },
  "keywords": [
    "whatsapp",
    "telegram",
    "bot",
    "renungan",
    "devotion",
    "ai",
    "webhook",
    "baileys"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.16",
    "@hapi/boom": "^9.1.4",
    "pino": "^9.6.0",
    "axios": "^1.7.9",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "fs-extra": "^11.2.0",
    "moment-timezone": "^0.5.45",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
