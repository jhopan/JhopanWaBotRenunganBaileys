# Environment Variables Configuration
# Bot Renungan Harian - WhatsApp + Telegram (Baileys)

# ============================================
# TIMEZONE
# ============================================
TIMEZONE=Asia/Makassar

# ============================================
# TELEGRAM BOT
# ============================================
TELEGRAM_BOT_TOKEN=your_t...n
# ============================================
# WEBHOOK MODE (RECOMMENDED untuk VPS)
# ============================================
WEBHOOK_URL=https://your-tunnel-domain.com
WEBHOOK_PORT=3000

# ============================================
# AI PROVIDER (pilih salah satu)
# ============================================

# Opsi 1: Custom OpenAI-Compatible API (RECOMMENDED)
AI_API_KEY=your_...n
# Opsi 3: Gemini (Google AI)
# GEMINI_API_KEY=key1,key2,key3

# ============================================
# RENUNGAN SETTINGS (opsional, bisa set via Telegram)
# ============================================
RENUNGAN_GROUP_ID=
RENUNGAN_TIME=08:00

# ============================================
# MONGODB (untuk persistent auth state)
# ============================================
# Opsi 1: Full connection string (RECOMMENDED)
# Untuk local:
# MONGODB_URI=mongodb://localhost:***@whatsapp_bot
# Untuk MongoDB Atlas:
# MONGODB_URI=mongodb+srv://user:***@cluster.mongodb.net/whatsapp_bot

# Opsi 2: Komponen terpisah (fallback)
# MONGO_HOST=localhost:27017
# MONGO_DB=whatsapp_bot
# MONGO_USER=
# MONGO_PASS=
